APP_URL=https://example-app.com
APP_NAME="Adamus KPI"
ALEMBIC_DATABASE_URL=mysql+pymysql://alembic_user:password@localhost/db_name
ALEMBIC_PASSWORD=password

DATABASE_URL="mysql+pymysql://db_user:password@localhost/db_name"
SEED_DB=true # Set it to false in production
MYSQL_DATABASE=db_name
MYSQL_USER=db_user
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=root_password

# Auth
SECRET_KEY="secret-key-change-me-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email (SMTP) – used to send the admin account confirmation email
EMAIL_PROVIDER="smtp"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="no-reply@example.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="Adamus KPI <no-reply@example.com>"
# RESEND EMAIL API
# Email (Resend API)
RESEND_API_KEY="api_key"
RESEND_FROM="sender_address"